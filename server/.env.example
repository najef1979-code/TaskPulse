# TaskPulse Environment Variables
# Copy this file to .env and update with your configuration

# Server Configuration
PORT=3000
NODE_ENV=development

# Custom Domain Configuration
# Set your custom domain here (without http:// or https://)
# Example: CUSTOM_DOMAIN=taskpulse.ceraimic.eu
# Leave empty if not using a custom domain
CUSTOM_DOMAIN=

# Cookie Configuration (for production)
# IMPORTANT: Change this to a random secure string in production!
COOKIE_SECRET=change-this-to-a-random-string-in-production